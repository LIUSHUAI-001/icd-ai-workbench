{
  "manifest_version": 3,
  "name": "T8 Penguin Canvas Web Image Reverse",
  "description": "网页图片反推、批量素材采集、截图并发送回 T8 画布。",
  "version": "1.2.0",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://vibex.runninghub.cn/*",
        "https://www.runninghub.cn/*",
        "https://runninghub.cn/*"
      ],
      "js": [
        "scripts/runninghub-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_title": "T8 网页素材采集",
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {}
}

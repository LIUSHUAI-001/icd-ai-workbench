{
  "name": "t8-penguin-canvas",
  "private": true,
  "version": "1.2.2",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "T8-penguin-canvas — AI 节点画布",
  "scripts": {
    "dev": "concurrently \"cd backend && npm start\" \"vite\"",
    "dev:vite": "vite",
    "dev:backend": "cd backend && npm start",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "encrypt": "npx electron electron/encrypt.cjs",
    "prepack:enc": "npm run build && npm run encrypt",
    "dist:dir": "npm run prepack:enc && npx electron-builder --mac --arm64 --dir",
    "dist": "npm run prepack:enc && npx electron-builder --mac --arm64"
  },
  "build": {
    "appId": "com.t8star.penguin-canvas",
    "productName": "T8-PenguinCanvas",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "electron/**/*",
      "!electron/encrypt.cjs",
      "!electron/_post_build.cjs",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "build/backend-enc",
        "to": "backend-enc"
      },
      {
        "from": "dist",
        "to": "frontend"
      },
      {
        "from": "backend/node_modules",
        "to": "backend-node_modules"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "dmg": {
      "title": "T8-PenguinCanvas"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/sharp/**",
      "node_modules/@img/**"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@xyflow/react": "^12.10.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "bytenode": "^1.5.7",
    "concurrently": "^9.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}

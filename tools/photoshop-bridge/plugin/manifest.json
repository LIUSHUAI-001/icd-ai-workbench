{
  "manifestVersion": 5,
  "id": "cn.t8star.penguin-canvas.photoshop-bridge",
  "name": "T8 Photoshop Link",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "24.0.0"
  },
  "requiredPermissions": {
    "network": {
      "domains": [
        "127.0.0.1",
        "localhost"
      ]
    },
    "launchProcess": {
      "schemes": [
        "http",
        "https"
      ]
    },
    "localFileSystem": "request"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "t8PhotoshopBridgePanel",
      "label": "T8 Photoshop Link",
      "minimumSize": {
        "width": 300,
        "height": 420
      },
      "maximumSize": {
        "width": 2400,
        "height": 2400
      },
      "preferredDockedSize": {
        "width": 430,
        "height": 760
      },
      "preferredFloatingSize": {
        "width": 720,
        "height": 860
      }
    }
  ]
}
